---
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/Card.astro';
import Section from '../components/Section.astro';
import publicData from '../content/public.json';
---

<BaseLayout title="Home">
  <div class="hero">
    <h2>Arkansas Baptist Disaster Relief</h2>
    <p>Volunteer resources, training links, and federal references for Arkansas disaster relief volunteers.</p>
    <div class="hero-actions">
      <a href={publicData.getInvolved[0].url} class="btn-primary" target="_blank" rel="noopener">
        <i class="fa-solid fa-hand-holding-heart" aria-hidden="true"></i> Get Involved
      </a>
      <a href={publicData.getInvolved[2].url} class="btn-secondary" target="_blank" rel="noopener">
        <i class="fa-solid fa-heart" aria-hidden="true"></i> Donate
      </a>
    </div>
  </div>

  <div class="callout">
    <i class="fa-solid fa-circle-info" aria-hidden="true"></i>&nbsp;
    {publicData.site.disclaimer} Visit the official site at
    <a href={publicData.site.officialSite} target="_blank" rel="noopener">abscdisasterrelief.org</a>.
  </div>

  <!-- Get Involved & Official -->
  <div class="card-grid">
    <Section title="Get Involved" icon="fa-hand-holding-heart">
      {publicData.getInvolved.map(item => (
        <Card icon={item.icon} label={item.label} desc={item.desc} url={item.url} />
      ))}
    </Section>

    <Section title="Official ABDR" icon="fa-circle-info">
      {publicData.official.map(item => (
        <Card icon={item.icon} label={item.label} desc={item.desc} url={item.url} />
      ))}
    </Section>
  </div>

  <!-- Training & Apps -->
  <h2 class="section-title"><i class="fa-solid fa-graduation-cap"></i> Training & Tools</h2>

  <div class="card-grid">
    <Section title="FEMA Courses" icon="fa-certificate">
      {publicData.training.map(item => (
        <Card icon={item.icon} label={item.label} desc={item.desc} url={item.url} />
      ))}
    </Section>

    <Section title="Mobile App & Training" icon="fa-mobile-screen-button">
      {publicData.apps.map(item => (
        <Card icon={item.icon} label={item.label} desc={item.desc} url={item.url} />
      ))}
      <Card icon="fa-graduation-cap" label="ABDR Training Events" desc="Upcoming volunteer training" url={publicData.getInvolved[1].url} />
      <Card icon="fa-book-open" label="Full FEMA Course Catalog" desc="All independent study courses" url={publicData.fema[2].url} />
    </Section>
  </div>

  <!-- FEMA & Federal -->
  <h2 class="section-title"><i class="fa-solid fa-landmark"></i> FEMA & Federal Resources</h2>

  <div class="fema-text-box">
    <h3><i class="fa-solid fa-mobile-screen-button"></i> FEMA Text Services</h3>
    <div>Text <span class="text-number">{publicData.femaText.number}</span> (4FEMA)</div>
    <ul>
      {publicData.femaText.commands.map(cmd => (
        <li><code>{cmd.command}</code> — {cmd.desc}</li>
      ))}
    </ul>
  </div>

  <div class="card-grid">
    <Section title="FEMA" icon="fa-landmark">
      {publicData.fema.map(item => (
        <Card icon={item.icon} label={item.label} desc={item.desc} url={item.url} />
      ))}
    </Section>

    <Section title="Federal & Partner" icon="fa-handshake">
      {publicData.federal.map(item => (
        <Card icon={item.icon} label={item.label} desc={item.desc} url={item.url} />
      ))}
    </Section>
  </div>


</BaseLayout>
