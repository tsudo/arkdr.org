---
interface Props {
  icon: string;
  label: string;
  desc: string;
  url: string;
}
const { icon, label, desc, url } = Astro.props;
const isExternal = url.startsWith('http');
---

<a class="link-btn" href={url} target={isExternal ? '_blank' : undefined} rel={isExternal ? 'noopener' : undefined}>
  <span class="btn-icon"><i class={icon.startsWith('fa-brands') ? icon : `fa-solid ${icon}`} aria-hidden="true"></i></span>
  <div class="btn-text">
    <div class="btn-label">{label}</div>
    <div class="btn-desc">{desc}</div>
  </div>
  <span class="btn-arrow" aria-hidden="true">&#8250;</span>
</a>
